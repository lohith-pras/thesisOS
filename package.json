{
  "name": "proofline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first research workspace that turns reviewer feedback into an evidence-backed change set.",
  "scripts": {
    "demo": "node src/cli.mjs",
    "review": "node src/review-cli.mjs",
    "zotero": "node src/zotero-cli.mjs",
    "app": "node src/app-server.mjs",
    "app:demo": "THESISOS_PORT=4174 node src/app-server.mjs --demo",
    "workspace": "node src/workspace-cli.mjs",
    "eval:retrieval": "node src/retrieval-eval-cli.mjs",
    "eval:citations": "node src/citation-eval-cli.mjs",
    "capture:submission": "node scripts/capture-submission.mjs",
    "test:browser": "node scripts/capture-submission.mjs --verify",
    "render:video": "node scripts/render-demo-video.mjs",
    "test": "node --test",
    "check": "node scripts/check-syntax.mjs",
    "check:frontend": "node --check app/app.js"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "pdfjs-dist": "^6.1.200"
  }
}
